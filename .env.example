# Sentry MCP Server configuration
# Copy this file to `.env` and fill in your values.

# Required: Your Sentry organization slug (shared across all users).
SENTRY_ORG=org-name

# Required: Base URL of your Sentry instance (self-hosted or sentry.io).
SENTRY_BASE_URL=https://sentry.your-org.com

# Optional: Default project slug used when a tool call doesn't pass `project`.
# Use the `list_projects` MCP tool to discover available slugs.
# SENTRY_DEFAULT_PROJECT_SLUG=backend-api

# --- Per-user authentication ---
# There is NO shared server token and NO MCP_API_KEY. Each user sends their own
# Sentry auth token in the "X-Sentry-Token" header; the server uses that token
# for that request. Token needs read scopes:
#   org:read, project:read, event:read, member:read
# Generate at: https://<your-sentry>/settings/account/api/auth-tokens/

# Header name carrying the per-user token (default X-Sentry-Token).
# SENTRY_TOKEN_HEADER=X-Sentry-Token

# --- HTTP mode (Docker / docker-compose) ---
MCP_HOST=0.0.0.0
MCP_PORT=8765
