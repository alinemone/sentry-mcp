# Sentry MCP Server configuration
# Copy this file to `.env` and fill in your values.

# Required: Sentry auth token.
# Needs read scopes: org:read, project:read, event:read, member:read.
# Generate at: https://<your-sentry>/settings/account/api/auth-tokens/
# or as an Internal Integration: https://<your-sentry>/settings/<org>/developer-settings/
SENTRY_TOKEN=sntryu_your_token_here

# Required: Your Sentry organization slug.
SENTRY_ORG=org-name

# Required: Base URL of your Sentry instance (self-hosted or sentry.io).
SENTRY_BASE_URL=https://sentry.your-org.com

# Optional: Default project slug used when a tool call doesn't pass `project`.
# Use the `list_projects` MCP tool to discover available slugs.
# SENTRY_DEFAULT_PROJECT_SLUG=backend-api

# --- HTTP mode (Docker / docker-compose) ---
# Only required when running the HTTP transport (e.g. via docker-compose).
# Generate a strong random value:  python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=change-me-to-a-long-random-string

# Port the container listens on (host:container in docker-compose.yml).
MCP_PORT=8765
